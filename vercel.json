{
  "buildCommand": "cd PersonalFit && npm run build",
  "outputDirectory": "PersonalFit/dist",
  "installCommand": "cd PersonalFit && npm install",
  "framework": null,
  "functions": {
    "api/*.ts": {
      "cwd": "PersonalFit"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
